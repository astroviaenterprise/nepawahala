rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'userName', 'status', 'location', 'timestamp'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.status in ['on', 'off']
        && data.location.address is string
        && data.location.placeId is string
        && data.timestamp == request.time;
    }

    match /logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidLog(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
  }
}
