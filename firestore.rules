rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Log Validation
    function isValidLog(data) {
      return data.keys().hasAll(['location', 'description', 'status', 'lat', 'lng', 'prediction', 'estimatedHours', 'timestamp']) &&
             data.keys().size() <= 10 &&
             data.location is string && data.location.size() <= 500 &&
             data.description is string && data.description.size() <= 1000 &&
             data.status in ['ON', 'OFF'] &&
             data.lat is number && data.lat >= -90 && data.lat <= 90 &&
             data.lng is number && data.lng >= -180 && data.lng <= 180 &&
             data.prediction is string && data.prediction.size() <= 500 &&
             data.estimatedHours is number &&
             data.timestamp == request.time;
    }

    match /logs/{logId} {
      // Allow anybody to read logs for the map
      allow get: if true;
      allow list: if true; // In a production app, we might limit this by geography or timestamp

      // Allow creating logs - ideally this would be isSignedIn() but the current UI is public
      allow create: if isValidLog(incoming()) && isValidId(logId);
      
      // Logs are immutable once created to prevent spoofing existing reports
      allow update, delete: if false;
    }
  }
}
